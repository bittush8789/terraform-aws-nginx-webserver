# Local directory for Terraform
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
# *.tfvars
# *.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include official tfvars configuration file as an exception
!terraform.tfvars

# Ignore CLI configuration files
.terraformrc
terraform.rc
